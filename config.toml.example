# MiMo WebUI 配置文件示例
# 复制为 config.toml 并填入你的实际配置

[server]
host = "0.0.0.0"
port = 3000

[auth]
jwt_secret = "change-me-to-random-string"              # 生产环境请改为随机字符串
jwt_expiry_hours = 24
open_registration = false
max_users = 10
admin_password = "change-me"                            # 首次启动创建 admin 账户的密码

[upload]
max_image_mb = 50
max_audio_mb = 100
max_video_mb = 500
temp_dir = "/tmp/mimo-uploads"
cleanup_interval_minutes = 30
file_expiry_minutes = 60

[rate_limit]
requests_per_minute = 30

[database]
path = "/etc/mimo-webui/mimo-webui.db"
